# gpuoffload — variables d'environnement
#
# Copiez ce fichier en .env sur le serveur de BASE (celui qui lance
# orchestrator.py) et remplissez les valeurs. NE JAMAIS committer le
# .env réel (déjà exclu par .gitignore).

# --- Requis uniquement pour le provider "runpod" ---

# Clé API RunPod (Settings > API Keys sur https://www.runpod.io).
RUNPOD_API_KEY=

# URL brute et publique pointant vers executor.py, que le pod RunPod
# télécharge au démarrage (curl). Le repo gpuoffload doit être public,
# ou hébergez le fichier ailleurs (gist public, etc.) :
#   https://raw.githubusercontent.com/ZeWills987/gpuoffload/main/executor.py
GPUOFFLOAD_EXECUTOR_URL=

# --- Requis pour tous les providers (local et runpod) ---

# Token bearer partagé entre l'orchestrateur et l'executor pour
# sécuriser les appels HTTP entre les deux. Générez-le une fois :
#   openssl rand -hex 32
# Le provider "local" le génère lui-même à la volée si absent ; pour
# "runpod", fixez-le ici pour qu'il soit identique des deux côtés.
GPUOFFLOAD_TOKEN=

# --- Optionnel ---

# Device utilisé par audiotwin.neural sur l'executor (auto-détecté sinon).
# AUDIOTWIN_DEVICE=cuda
